{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": "Product data used by rankings, affiliate links and dynamic pages."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "shortDescription": {
      "type": "text"
    },
    "marketplaceProductId": {
      "type": "string"
    },
    "marketplaceUrl": {
      "type": "string"
    },
    "imageUrl": {
      "type": "string"
    },
    "price": {
      "type": "decimal"
    },
    "oldPrice": {
      "type": "decimal"
    },
    "currency": {
      "type": "string",
      "default": "BRL"
    },
    "rating": {
      "type": "decimal"
    },
    "reviewCount": {
      "type": "integer"
    },
    "soldQuantity": {
      "type": "integer"
    },
    "brand": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "attributes": {
      "type": "json"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "imported",
        "review",
        "approved",
        "rejected",
        "archived"
      ],
      "default": "imported"
    },
    "lastSyncedAt": {
      "type": "datetime"
    },
    "marketplace": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::marketplace.marketplace",
      "inversedBy": "products"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "products"
    },
    "subCategory": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::sub-category.sub-category",
      "inversedBy": "products"
    },
    "affiliateLinks": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::affiliate-link.affiliate-link",
      "mappedBy": "product"
    },
    "rankingItems": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::ranking-item.ranking-item",
      "mappedBy": "product"
    }
  }
}
