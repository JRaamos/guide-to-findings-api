{
  "kind": "collectionType",
  "collectionName": "ranking_items",
  "info": {
    "singularName": "ranking-item",
    "pluralName": "ranking-items",
    "displayName": "RankingItem",
    "description": "Product position inside a ranking."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "position": {
      "type": "integer",
      "required": true
    },
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "text"
    },
    "pros": {
      "type": "json"
    },
    "cons": {
      "type": "json"
    },
    "highlight": {
      "type": "string"
    },
    "score": {
      "type": "decimal"
    },
    "ctaText": {
      "type": "string"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "active",
        "inactive"
      ],
      "default": "active"
    },
    "ranking": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::ranking.ranking",
      "inversedBy": "items"
    },
    "product": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product.product",
      "inversedBy": "rankingItems"
    },
    "affiliateLink": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::affiliate-link.affiliate-link"
    }
  }
}
