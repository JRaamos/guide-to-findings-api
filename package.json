    "axios": "1.5.0",
    "dotenv": "^16.5.0",
    "moment": "2.29.4",
    "pg": "8.13.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0"
  },
  "author": {
    "name": "xApps Team"
