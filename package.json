  "private": true,
  "version": "0.1.0",
  "description": "Api for Guide to findings Application",
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "develop": "strapi develop",
    "generate": "strapi generate",
    "services": "strapi services:list",
    "watch": "strapi develop --watch-admin",
    "start": "strapi start",
    "build": "strapi build && node config/scripts.js",
    "seed:local": "node scripts/seed-local.js",
    "sync:ml:term": "node scripts/sync-mercadolivre-ranking-by-term.js",
    "sync:ml:publish": "node scripts/sync-generate-publish-mercadolivre-ranking.js",
    "cleanup:production": "node scripts/production-cleanup.js",
    "strapi": "strapi",
    "export:roles": "EXPORT_ROLES=true yarn develop",
    "import:roles": "UPDATE_ROLES=true yarn develop"
  },
  "devDependencies": {
    "@eslint/js": "^9.4.0",
